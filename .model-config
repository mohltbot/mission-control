# Model Routing Configuration - ACTIVE
# Switched to mixed models on 2026-02-26

# Primary model for this session
DEFAULT_MODEL=moonshot/kimi-k2.5

# Cost-optimized routing
# Simple tasks -> Cheaper models automatically
USE_MIXED_ROUTING=true

# Model priority (cheapest first)
TIER_1=gemini/gemini-1.5-flash  # FREE - simple chats
TIER_2=deepseek/deepseek-chat   # $0.0003/1K - standard work
TIER_3=moonshot/kimi-k2.5       # $0.0015/1K - complex tasks

# Fallback
FALLBACK_MODEL=moonshot/kimi-k2.5
