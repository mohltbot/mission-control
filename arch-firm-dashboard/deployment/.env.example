# ArchTrack Environment Configuration
# Copy this file to .env and update with your settings

# ============================================
# Server Configuration
# ============================================
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# ============================================
# Database
# ============================================
DATABASE_URL=sqlite:/data/archtrack.db

# ============================================
# Admin Credentials
# ============================================
# CHANGE THESE DEFAULTS!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ============================================
# Optional: Discord Notifications
# ============================================
# Uncomment and set to enable Discord alerts
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# ============================================
# Optional: Email Notifications
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# ALERT_EMAIL=manager@company.com

# ============================================
# Security
# ============================================
# Session secret (generate a random string)
SESSION_SECRET=change-this-to-a-random-string-at-least-32-characters

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Feature Flags
# ============================================
ENABLE_SUSPICIOUS_ACTIVITY_ALERTS=true
ENABLE_PRODUCTIVITY_REPORTS=true
ENABLE_REAL_TIME_UPDATES=true

# ============================================
# Desktop Tracker Settings
# ============================================
TRACKER_HEARTBEAT_INTERVAL=30000
TRACKER_IDLE_THRESHOLD=300000
