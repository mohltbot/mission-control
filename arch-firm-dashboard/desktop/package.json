{
  "name": "@archtrack/desktop",
  "version": "1.0.0",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run build:preload && concurrently \"vite\" \"tsc -w\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "npm run build:preload && tsc && vite build",
    "build:preload": "tsc src/preload/preload.ts --outDir dist/preload --module commonjs --target es2020 --lib es2020,dom --declaration --esModuleInterop",
    "start": "electron .",
    "package": "electron-builder"
  },
  "dependencies": {
    "@archtrack/shared": "file:../shared",
    "better-sqlite3": "^9.4.0",
    "electron-store": "^8.1.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.archtrack.desktop",
    "productName": "ArchTrack",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}