{
  "name": "archtrack",
  "version": "1.0.0",
  "description": "Employee monitoring system for architectural firms",
  "private": true,
  "workspaces": [
    "desktop",
    "admin",
    "shared"
  ],
  "scripts": {
    "dev:desktop": "cd desktop && npm run dev",
    "dev:admin": "cd admin && npm run dev",
    "dev": "concurrently \"npm run dev:admin\" \"npm run dev:desktop\"",
    "build": "npm run build:shared && npm run build:desktop && npm run build:admin",
    "build:shared": "cd shared && npm run build",
    "build:desktop": "cd desktop && npm run build",
    "build:admin": "cd admin && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}