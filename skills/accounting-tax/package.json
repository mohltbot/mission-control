{
  "name": "accounting-tax",
  "version": "1.0.0",
  "description": "Comprehensive accounting and tax automation for CPAs, bookkeepers, and finance professionals. Automates reconciliations, tax calculations, financial analysis, and compliance checks.",
  "author": "Mohammed Wasif, CPA",
  "license": "MIT",
  "keywords": [
    "accounting",
    "tax",
    "cpa",
    "bookkeeping",
    "finance",
    "reconciliation",
    "compliance",
    "automation"
  ],
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "decimal.js": "^10.4.3",
    "date-fns": "^3.3.0",
    "csv-parse": "^5.5.0",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0"
  },
  "clawSkill": {
    "category": "finance",
    "entryPoints": [
      {
        "command": "reconcile",
        "description": "Reconcile bank statements with general ledger"
      },
      {
        "command": "tax-calc",
        "description": "Calculate tax liabilities and estimates"
      },
      {
        "command": "financial-analysis",
        "description": "Analyze financial statements and ratios"
      },
      {
        "command": "compliance-check",
        "description": "Check accounting compliance and standards"
      },
      {
        "command": "depreciation",
        "description": "Calculate depreciation schedules"
      },
      {
        "command": "variance",
        "description": "Analyze budget vs actual variances"
      }
    ],
    "permissions": [
      "fileSystem:read",
      "fileSystem:write",
      "network:fetch"
    ]
  }
}
