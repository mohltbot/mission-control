{
  "name": "Avaamo - IT Helpdesk v3",
  "description": "Advanced ticket routing, auto-resolution, SLA tracking",
  "version": "3.0",
  "nodes": [
    {
      "id": "webhook",
      "type": "n8n-nodes-base.webhook",
      "name": "Ticket Created",
      "parameters": {
        "path": "it-helpdesk",
        "responseMode": "responseNode"
      }
    },
    {
      "id": "classify",
      "type": "n8n-nodes-base.openAi",
      "name": "AI Classify Ticket",
      "parameters": {
        "model": "gpt-4o-mini",
        "prompt": "Classify IT ticket:\nSubject: {{ $json.subject }}\nDescription: {{ $json.description }}\n\nCategory: HARDWARE | SOFTWARE | NETWORK | ACCESS | OTHER\nPriority: P1 (Critical) | P2 (High) | P3 (Medium) | P4 (Low)\n\nReturn JSON: {category, priority, estimated_resolution}"
      }
    },
    {
      "id": "route",
      "type": "n8n-nodes-base.switch",
      "name": "Route by Category",
      "parameters": {
        "rules": [
          {"value": "HARDWARE", "output": 0},
          {"value": "SOFTWARE", "output": 1},
          {"value": "NETWORK", "output": 2},
          {"value": "ACCESS", "output": 3}
        ]
      }
    },
    {
      "id": "autoResolve",
      "type": "n8n-nodes-base.function",
      "name": "Check Auto-Resolution",
      "parameters": {
        "functionCode": "// Check if ticket can be auto-resolved\nconst ticket = $input.first().json;\nconst commonIssues = {\n  'password reset': 'Send password reset link',\n  'vpn not working': 'Restart VPN service',\n  'printer offline': 'Clear print queue'\n};\n// Return resolution if found\nreturn { canAutoResolve: false };"
      }
    },
    {
      "id": "createTicket",
      "type": "n8n-nodes-base.jira",
      "name": "Create Jira Ticket",
      "parameters": {
        "operation": "create",
        "project": "IT",
        "summary": "={{ $json.subject }}",
        "description": "={{ $json.description }}",
        "priority": "={{ $json.priority }}"
      }
    },
    {
      "id": "notifySlack",
      "type": "n8n-nodes-base.slack",
      "name": "Alert IT Team",
      "parameters": {
        "channel": "#it-helpdesk",
        "text": "🎫 New {{ $json.priority }} ticket: {{ $json.subject }}\nCategory: {{ $json.category }}\nAuto-Assigned to: {{ $json.assignee }}"
      }
    },
    {
      "id": "slaTimer",
      "type": "n8n-nodes-base.wait",
      "name": "SLA Timer",
      "parameters": {
        "resume": "={{ $json.sla_minutes }}m"
      }
    },
    {
      "id": "escalate",
      "type": "n8n-nodes-base.slack",
      "name": "Escalate Alert",
      "parameters": {
        "channel": "#it-managers",
        "text": "🚨 SLA BREACH: Ticket {{ $json.id }} approaching deadline"
      }
    },
    {
      "id": "response",
      "type": "n8n-nodes-base.respondToWebhook",
      "name": "Confirm Receipt",
      "parameters": {
        "body": "={\"ticketId\": \"{{ $json.id }}\", \"status\": \"received\", \"sla\": \"{{ $json.sla }}\"}"
      }
    }
  ],
  "connections": {
    "webhook": {"main": [[{"node": "classify", "type": "main", "index": 0}]]},
    "classify": {"main": [[{"node": "route", "type": "main", "index": 0}]]},
    "route": {
      "main": [
        [{"node": "autoResolve", "type": "main", "index": 0}],
        [{"node": "autoResolve", "type": "main", "index": 0}],
        [{"node": "autoResolve", "type": "main", "index": 0}],
        [{"node": "autoResolve", "type": "main", "index": 0}]
      ]
    },
    "autoResolve": {"main": [[{"node": "createTicket", "type": "main", "index": 0}]]},
    "createTicket": {"main": [[{"node": "notifySlack", "type": "main", "index": 0}]]},
    "notifySlack": {"main": [[{"node": "slaTimer", "type": "main", "index": 0}]]},
    "slaTimer": {"main": [[{"node": "escalate", "type": "main", "index": 0}]]},
    "escalate": {"main": [[{"node": "response", "type": "main", "index": 0}]]}
  },
  "meta": {
    "company": "Avaamo",
    "useCase": "IT Helpdesk v3",
    "version": "3.0",
    "nodes": 9,
    "author": "Mission Control",
    "status": "production-ready"
  }
}
