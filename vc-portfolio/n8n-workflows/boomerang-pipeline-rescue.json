{
  "name": "Boomerang - Pipeline Rescue Agent",
  "description": "Detects champion job changes, drafts outreach, queues for sales rep",
  "version": "2.0",
  "nodes": [
    {
      "id": "trigger",
      "type": "n8n-nodes-base.webhook",
      "name": "Champion Changed Jobs",
      "parameters": {
        "path": "champion-job-change",
        "responseMode": "responseNode"
      }
    },
    {
      "id": "enrich",
      "type": "n8n-nodes-base.clearbit",
      "name": "Enrich New Company",
      "parameters": {
        "email": "={{ $json.newEmail }}"
      }
    },
    {
      "id": "checkCRM",
      "type": "n8n-nodes-base.salesforce",
      "name": "Check CRM History",
      "parameters": {
        "operation": "search",
        "object": "Opportunity",
        "query": "ContactId = '{{ $json.championId }}' AND IsClosed = true"
      }
    },
    {
      "id": "draftEmail",
      "type": "n8n-nodes-base.openAi",
      "name": "Draft Congrats Email",
      "parameters": {
        "model": "gpt-4o",
        "prompt": "Draft a personalized congratulatory email for {{ $json.championName }} who just moved to {{ $json.newCompany }} as {{ $json.newTitle }}. Reference our past successful project together at {{ $json.oldCompany }}. Keep it warm, genuine, and suggest catching up."
      }
    },
    {
      "id": "createTask",
      "type": "n8n-nodes-base.salesforce",
      "name": "Queue for Sales Rep",
      "parameters": {
        "operation": "create",
        "object": "Task",
        "subject": "REACH OUT: {{ $json.championName }} moved to {{ $json.newCompany }}",
        "description": "{{ $json.draftedEmail }}",
        "assignedTo": "={{ $json.salesRepId }}",
        "priority": "High"
      }
    },
    {
      "id": "slackAlert",
      "type": "n8n-nodes-base.slack",
      "name": "Alert Sales Team",
      "parameters": {
        "channel": "#pipeline-rescue",
        "text": "🎯 PIPELINE RESCUE ALERT\n{{ $json.championName }} → {{ $json.newCompany }} ({{ $json.newTitle }})\nPrevious: {{ $json.oldCompany }}\n\nDrafted email ready for {{ $json.salesRepName }}"
      }
    },
    {
      "id": "log",
      "type": "n8n-nodes-base.googleSheets",
      "name": "Log Rescue Opportunity",
      "parameters": {
        "operation": "append",
        "sheetId": "pipeline-rescues",
        "range": "Rescues!A:F",
        "values": [
          "={{ $now }}",
          "={{ $json.championName }}",
          "={{ $json.newCompany }}",
          "={{ $json.salesRepName }}",
          "Pending",
          "={{ $json.newTitle }}"
        ]
      }
    }
  ],
  "connections": {
    "trigger": {"main": [[{"node": "enrich", "type": "main", "index": 0}]]},
    "enrich": {"main": [[{"node": "checkCRM", "type": "main", "index": 0}]]},
    "checkCRM": {"main": [[{"node": "draftEmail", "type": "main", "index": 0}]]},
    "draftEmail": {"main": [[{"node": "createTask", "type": "main", "index": 0}]]},
    "createTask": {"main": [[{"node": "slackAlert", "type": "main", "index": 0}]]},
    "slackAlert": {"main": [[{"node": "log", "type": "main", "index": 0}]]}
  },
  "meta": {
    "company": "Boomerang",
    "useCase": "Pipeline Rescue Agent",
    "version": "2.0",
    "nodes": 7,
    "author": "Mission Control",
    "status": "production-ready"
  }
}
