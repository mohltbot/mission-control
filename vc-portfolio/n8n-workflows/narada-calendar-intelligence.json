{
  "name": "Narada - Calendar Intelligence",
  "description": "Auto-scheduling, conflict resolution, smart meeting management",
  "version": "2.0",
  "nodes": [
    {
      "id": "trigger",
      "type": "n8n-nodes-base.webhook",
      "name": "Calendar Request",
      "webhookId": "calendar-intelligence",
      "parameters": {
        "path": "calendar-intelligence",
        "responseMode": "responseNode"
      }
    },
    {
      "id": "parse",
      "type": "n8n-nodes-base.function",
      "name": "Parse Request",
      "parameters": {
        "functionCode": "// Extract meeting details\nconst request = $input.first().json;\nreturn {\n  title: request.title,\n  duration: request.duration || 30,\n  attendees: request.attendees || [],\n  priority: request.priority || 'normal',\n  constraints: request.constraints || {}\n};"
      }
    },
    {
      "id": "checkConflicts",
      "type": "n8n-nodes-base.googleCalendar",
      "name": "Check Calendar",
      "parameters": {
        "operation": "getAll",
        "calendar": "primary",
        "timeMin": "={{ $now }}",
        "timeMax": "={{ DateTime.now().plus({ days: 7 }) }}"
      }
    },
    {
      "id": "findSlots",
      "type": "n8n-nodes-base.function",
      "name": "Find Available Slots",
      "parameters": {
        "functionCode": "// Algorithm to find best meeting times\nconst events = $input.all()[0].json;\nconst request = $input.all()[1].json;\n// Return top 3 available slots\nreturn { availableSlots: findOptimalSlots(events, request) };"
      }
    },
    {
      "id": "checkAttendees",
      "type": "n8n-nodes-base.googleCalendar",
      "name": "Check Attendee Calendars",
      "parameters": {
        "operation": "availability",
        "attendees": "={{ $json.attendees }}"
      }
    },
    {
      "id": "schedule",
      "type": "n8n-nodes-base.googleCalendar",
      "name": "Schedule Meeting",
      "parameters": {
        "operation": "create",
        "calendar": "primary",
        "summary": "={{ $json.title }}",
        "start": "={{ $json.selectedSlot.start }}",
        "end": "={{ $json.selectedSlot.end }}",
        "attendees": "={{ $json.attendees }}"
      }
    },
    {
      "id": "notify",
      "type": "n8n-nodes-base.slack",
      "name": "Send Confirmation",
      "parameters": {
        "channel": "#calendar-updates",
        "text": "✅ Meeting scheduled: {{ $json.title }} at {{ $json.start }}"
      }
    },
    {
      "id": "response",
      "type": "n8n-nodes-base.respondToWebhook",
      "name": "Return Result",
      "parameters": {
        "statusCode": 200,
        "body": "={\"success\": true, \"meetingId\": \"{{ $json.id }}\", \"scheduledAt\": \"{{ $json.start }}\"}"
      }
    }
  ],
  "connections": {
    "trigger": {
      "main": [[{"node": "parse", "type": "main", "index": 0}]]
    },
    "parse": {
      "main": [[{"node": "checkConflicts", "type": "main", "index": 0}]]
    },
    "checkConflicts": {
      "main": [[{"node": "findSlots", "type": "main", "index": 0}]]
    },
    "findSlots": {
      "main": [[{"node": "checkAttendees", "type": "main", "index": 0}]]
    },
    "checkAttendees": {
      "main": [[{"node": "schedule", "type": "main", "index": 0}]]
    },
    "schedule": {
      "main": [[{"node": "notify", "type": "main", "index": 0}]]
    },
    "notify": {
      "main": [[{"node": "response", "type": "main", "index": 0}]]
    }
  },
  "meta": {
    "company": "Narada",
    "useCase": "Calendar Intelligence",
    "version": "2.0",
    "author": "Mission Control",
    "estimatedTime": "2 hours",
    "status": "template-ready"
  }
}
