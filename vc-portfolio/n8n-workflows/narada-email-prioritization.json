{
  "name": "Narada - Email Prioritization",
  "description": "Smart inbox, auto-prioritization, auto-responses",
  "version": "2.0",
  "nodes": [
    {
      "id": "trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "name": "New Email",
      "parameters": {
        "event": "messageReceived",
        "filters": {
          "unread": true
        }
      }
    },
    {
      "id": "analyze",
      "type": "n8n-nodes-base.openAi",
      "name": "AI Analyze Priority",
      "parameters": {
        "operation": "createCompletion",
        "model": "gpt-4o-mini",
        "prompt": "Analyze email priority:\nFrom: {{ $json.from }}\nSubject: {{ $json.subject }}\nBody: {{ $json.body }}\n\nClassify as: URGENT, HIGH, NORMAL, LOW"
      }
    },
    {
      "id": "route",
      "type": "n8n-nodes-base.switch",
      "name": "Route by Priority",
      "parameters": {
        "rules": {
          "rules": [
            {"value": "URGENT", "output": 0},
            {"value": "HIGH", "output": 1},
            {"value": "NORMAL", "output": 2},
            {"value": "LOW", "output": 3}
          ]
        }
      }
    },
    {
      "id": "urgentAlert",
      "type": "n8n-nodes-base.slack",
      "name": "Urgent Alert",
      "parameters": {
        "channel": "#urgent-emails",
        "text": "🚨 URGENT EMAIL\nFrom: {{ $json.from }}\nSubject: {{ $json.subject }}"
      }
    },
    {
      "id": "autoReply",
      "type": "n8n-nodes-base.gmail",
      "name": "Send Auto-Reply",
      "parameters": {
        "operation": "send",
        "to": "={{ $json.from }}",
        "subject": "Re: {{ $json.subject }}",
        "body": "Thank you for your email. This is an automated response. I'll get back to you within 24 hours."
      }
    },
    {
      "id": "label",
      "type": "n8n-nodes-base.gmail",
      "name": "Apply Label",
      "parameters": {
        "operation": "label",
        "messageId": "={{ $json.id }}",
        "labelIds": ["Label_1"]
      }
    },
    {
      "id": "log",
      "type": "n8n-nodes-base.googleSheets",
      "name": "Log to Spreadsheet",
      "parameters": {
        "operation": "append",
        "sheetId": "your-sheet-id",
        "range": "Emails!A:D",
        "values": [
          "={{ $now }}",
          "={{ $json.from }}",
          "={{ $json.subject }}",
          "={{ $json.priority }}"
        ]
      }
    }
  ],
  "connections": {
    "trigger": {
      "main": [[{"node": "analyze", "type": "main", "index": 0}]]
    },
    "analyze": {
      "main": [[{"node": "route", "type": "main", "index": 0}]]
    },
    "route": {
      "main": [
        [{"node": "urgentAlert", "type": "main", "index": 0}],
        [{"node": "autoReply", "type": "main", "index": 0}],
        [{"node": "label", "type": "main", "index": 0}],
        [{"node": "log", "type": "main", "index": 0}]
      ]
    }
  },
  "meta": {
    "company": "Narada",
    "useCase": "Email Prioritization",
    "version": "2.0",
    "author": "Mission Control",
    "estimatedTime": "2 hours",
    "status": "template-ready"
  }
}
