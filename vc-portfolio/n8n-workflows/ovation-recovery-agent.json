{
  "name": "Ovation - Recovery Agent",
  "description": "Detects negative reviews, drafts apology/coupon, asks GM to approve",
  "version": "2.0",
  "nodes": [
    {
      "id": "trigger",
      "type": "n8n-nodes-base.webhook",
      "name": "New Review",
      "parameters": {
        "path": "review-received",
        "responseMode": "responseNode"
      }
    },
    {
      "id": "sentiment",
      "type": "n8n-nodes-base.openAi",
      "name": "Analyze Sentiment",
      "parameters": {
        "model": "gpt-4o-mini",
        "prompt": "Classify this review sentiment: POSITIVE, NEUTRAL, or NEGATIVE.\n\nReview: {{ $json.reviewText }}\n\nRating: {{ $json.rating }}/5"
      }
    },
    {
      "id": "checkNegative",
      "type": "n8n-nodes-base.if",
      "name": "Is Negative?",
      "parameters": {
        "conditions": {
          "options": {
            "leftValue": "={{ $json.sentiment }}",
            "operator": {"type": "string", "operation": "equals"},
            "rightValue": "NEGATIVE"
          }
        }
      }
    },
    {
      "id": "identifyIssue",
      "type": "n8n-nodes-base.openAi",
      "name": "Identify Issue",
      "parameters": {
        "model": "gpt-4o",
        "prompt": "Analyze this negative review and identify:\n1. Main complaint category (food, service, cleanliness, wait time, etc.)\n2. Specific issue mentioned\n3. Severity (1-5)\n\nReview: {{ $json.reviewText }}"
      }
    },
    {
      "id": "draftResponse",
      "type": "n8n-nodes-base.openAi",
      "name": "Draft Apology",
      "parameters": {
        "model": "gpt-4o",
        "prompt": "Draft a personalized apology response to this negative review:\n\nReview: {{ $json.reviewText }}\nIssue: {{ $json.issue }}\n\nRequirements:\n- Acknowledge specific issue\n- Sincere apology\n- Offer $25 credit (include code)\n- Invite back\n- Professional but warm tone"
      }
    },
    {
      "id": "generateCode",
      "type": "n8n-nodes-base.function",
      "name": "Create Coupon Code",
      "parameters": {
        "functionCode": "const reviewId = $input.first().json.reviewId;\nconst code = 'SORRY' + reviewId.slice(-4) + Math.floor(Math.random() * 1000);\nreturn { couponCode: code, discount: '$25 off next visit' };"
      }
    },
    {
      "id": "requestApproval",
      "type": "n8n-nodes-base.slack",
      "name": "Ask GM to Approve",
      "parameters": {
        "channel": "@gm",
        "text": "🚨 NEGATIVE REVIEW ALERT\n\n**Location:** {{ $json.location }}\n**Rating:** {{ $json.rating }}/5\n**Issue:** {{ $json.issue }}\n\n**Drafted Response:**\n{{ $json.draft }}\n\n**Coupon:** {{ $json.couponCode }} ({{ $json.discount }})\n\nReply ✅ to approve or ✏️ to edit."
      }
    },
    {
      "id": "log",
      "type": "n8n-nodes-base.googleSheets",
      "name": "Log Recovery",
      "parameters": {
        "operation": "append",
        "sheetId": "recovery-log",
        "range": "Log!A:F",
        "values": [
          "={{ $now }}",
          "={{ $json.location }}",
          "={{ $json.rating }}",
          "={{ $json.issue }}",
          "{{ $json.couponCode }}",
          "Pending Approval"
        ]
      }
    }
  ],
  "connections": {
    "trigger": {"main": [[{"node": "sentiment", "type": "main", "index": 0}]]},
    "sentiment": {"main": [[{"node": "checkNegative", "type": "main", "index": 0}]]},
    "checkNegative": {
      "main": [
        [{"node": "identifyIssue", "type": "main", "index": 0}],
        [{"node": "log", "type": "main", "index": 0}]
      ]
    },
    "identifyIssue": {"main": [[{"node": "draftResponse", "type": "main", "index": 0}]]},
    "draftResponse": {"main": [[{"node": "generateCode", "type": "main", "index": 0}]]},
    "generateCode": {"main": [[{"node": "requestApproval", "type": "main", "index": 0}]]},
    "requestApproval": {"main": [[{"node": "log", "type": "main", "index": 0}]]}
  },
  "meta": {
    "company": "Ovation",
    "useCase": "Recovery Agent",
    "version": "2.0",
    "nodes": 8,
    "author": "Mission Control",
    "status": "production-ready"
  }
}
