{
  "name": "Universal - Analytics Dashboard",
  "description": "Cross-platform reporting from CRM, ERP, Support systems",
  "version": "2.0",
  "nodes": [
    {
      "id": "scheduleTrigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "name": "Daily at 8 AM",
      "parameters": {
        "rule": {
          "interval": [{
            "field": "hour",
            "hours": 8
          }]
        }
      }
    },
    {
      "id": "getCRMData",
      "type": "n8n-nodes-base.salesforce",
      "name": "Get CRM Metrics",
      "parameters": {
        "operation": "search",
        "object": "Opportunity",
        "query": "SELECT Id, Amount, StageName, CloseDate FROM Opportunity WHERE IsClosed = false"
      }
    },
    {
      "id": "getERPData",
      "type": "n8n-nodes-base.httpRequest",
      "name": "Get ERP Revenue",
      "parameters": {
        "method": "GET",
        "url": "https://erp.company.com/api/revenue?period=month"
      }
    },
    {
      "id": "getSupportData",
      "type": "n8n-nodes-base.zendesk",
      "name": "Get Support Metrics",
      "parameters": {
        "operation": "list",
        "ticketCount": 100
      }
    },
    {
      "id": "aggregate",
      "type": "n8n-nodes-base.merge",
      "name": "Aggregate Data"
    },
    {
      "id": "calculateMetrics",
      "type": "n8n-nodes-base.function",
      "name": "Calculate KPIs",
      "parameters": {
        "functionCode": "const crm = $input.all()[0].json;\nconst erp = $input.all()[1].json;\nconst support = $input.all()[2].json;\n\n// Calculate metrics\nconst metrics = {\n  sales: {\n    pipeline: crm.totalValue || 0,\n    dealsCount: crm.deals?.length || 0,\n    avgDealSize: crm.totalValue / (crm.deals?.length || 1)\n  },\n  finance: {\n    revenue: erp.revenue || 0,\n    expenses: erp.expenses || 0,\n    profit: (erp.revenue || 0) - (erp.expenses || 0)\n  },\n  support: {\n    openTickets: support.open || 0,\n    avgResponseTime: support.avgResponse || 0,\n    csat: support.csat || 0\n  },\n  date: new Date().toISOString()\n};\nreturn metrics;"
      }
    },
    {
      "id": "chart1",
      "type": "n8n-nodes-base.googleSheets",
      "name": "Update Revenue Chart",
      "parameters": {
        "operation": "append",
        "sheetId": "analytics-dashboard",
        "range": "Revenue!A:D",
        "values": [
          "={{ $now }}",
          "={{ $json.finance.revenue }}",
          "={{ $json.finance.expenses }}",
          "={{ $json.finance.profit }}"
        ]
      }
    },
    {
      "id": "chart2",
      "type": "n8n-nodes-base.googleSheets",
      "name": "Update Pipeline Chart",
      "parameters": {
        "operation": "append",
        "sheetId": "analytics-dashboard",
        "range": "Pipeline!A:C",
        "values": [
          "={{ $now }}",
          "={{ $json.sales.pipeline }}",
          "={{ $json.sales.dealsCount }}"
        ]
      }
    },
    {
      "id": "slackReport",
      "type": "n8n-nodes-base.slack",
      "name": "Post to #analytics",
      "parameters": {
        "channel": "#analytics",
        "text": "📊 Daily Analytics Report\n\n💰 Revenue: ${{ $json.finance.revenue }}\n💵 Profit: ${{ $json.finance.profit }}\n\n📈 Pipeline: ${{ $json.sales.pipeline }}\n🎯 Deals: {{ $json.sales.dealsCount }}\n\n🎫 Support: {{ $json.support.openTickets }} open tickets\n⭐ CSAT: {{ $json.support.csat }}%"
      }
    },
    {
      "id": "archive",
      "type": "n8n-nodes-base.googleDrive",
      "name": "Archive Report",
      "parameters": {
        "operation": "upload",
        "folder": "Analytics/$(date +%Y-%m)",
        "file": "daily-report-$(date +%Y-%m-%d).json",
        "data": "={{ $json }}"
      }
    }
  ],
  "connections": {
    "scheduleTrigger": {"main": [[{"node": "getCRMData", "type": "main", "index": 0}]]},
    "getCRMData": {"main": [[{"node": "getERPData", "type": "main", "index": 0}]]},
    "getERPData": {"main": [[{"node": "getSupportData", "type": "main", "index": 0}]]},
    "getSupportData": {"main": [[{"node": "aggregate", "type": "main", "index": 0}]]},
    "aggregate": {"main": [[{"node": "calculateMetrics", "type": "main", "index": 0}]]},
    "calculateMetrics": {
      "main": [
        [{"node": "chart1", "type": "main", "index": 0}],
        [{"node": "chart2", "type": "main", "index": 0}],
        [{"node": "slackReport", "type": "main", "index": 0}]
      ]
    },
    "chart1": {"main": [[{"node": "archive", "type": "main", "index": 0}]]}
  },
  "meta": {
    "company": "Universal",
    "useCase": "Analytics Dashboard",
    "version": "2.0",
    "nodes": 10,
    "author": "Mission Control",
    "status": "production-ready",
    "frequency": "Daily at 8 AM"
  }
}
