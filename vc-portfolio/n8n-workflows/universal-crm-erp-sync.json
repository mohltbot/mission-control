{
  "name": "Universal - CRM-to-ERP Sync",
  "description": "Bi-directional sync between Salesforce CRM and NetSuite ERP",
  "version": "2.0",
  "nodes": [
    {
      "id": "crmTrigger",
      "type": "n8n-nodes-base.salesforceTrigger",
      "name": "CRM Update",
      "parameters": {
        "event": "onUpdate",
        "object": "Account"
      }
    },
    {
      "id": "erpTrigger",
      "type": "n8n-nodes-base.httpTrigger",
      "name": "ERP Webhook",
      "parameters": {
        "path": "erp-sync"
      }
    },
    {
      "id": "merge",
      "type": "n8n-nodes-base.merge",
      "name": "Merge Sources"
    },
    {
      "id": "transform",
      "type": "n8n-nodes-base.function",
      "name": "Transform Data",
      "parameters": {
        "functionCode": "const record = $input.first().json;\nreturn {\n  customerId: record.Id || record.entityId,\n  name: record.Name || record.companyName,\n  email: record.Email || record.email,\n  phone: record.Phone || record.phone,\n  address: record.BillingAddress || record.address,\n  lastModified: new Date().toISOString()\n};"
      }
    },
    {
      "id": "checkExisting",
      "type": "n8n-nodes-base.salesforce",
      "name": "Check CRM",
      "parameters": {
        "operation": "search",
        "object": "Account",
        "query": "Id = '{{ $json.customerId }}'"
      }
    },
    {
      "id": "updateCRM",
      "type": "n8n-nodes-base.salesforce",
      "name": "Update CRM",
      "parameters": {
        "operation": "update",
        "object": "Account",
        "id": "={{ $json.customerId }}",
        "fields": {
          "Name": "={{ $json.name }}",
          "Phone": "={{ $json.phone }}",
          "BillingAddress": "={{ $json.address }}"
        }
      }
    },
    {
      "id": "updateERP",
      "type": "n8n-nodes-base.httpRequest",
      "name": "Update ERP",
      "parameters": {
        "method": "PUT",
        "url": "https://erp.company.com/api/customers/{{ $json.customerId }}",
        "body": "={{ $json }}"
      }
    },
    {
      "id": "log",
      "type": "n8n-nodes-base.googleSheets",
      "name": "Log Sync",
      "parameters": {
        "operation": "append",
        "sheetId": "sync-log",
        "range": "Log!A:D",
        "values": [
          "={{ $now }}",
          "={{ $json.customerId }}",
          "SYNCED",
          "bi-directional"
        ]
      }
    }
  ],
  "connections": {
    "crmTrigger": {"main": [[{"node": "merge", "type": "main", "index": 0}]]},
    "erpTrigger": {"main": [[{"node": "merge", "type": "main", "index": 1}]]},
    "merge": {"main": [[{"node": "transform", "type": "main", "index": 0}]]},
    "transform": {"main": [[{"node": "checkExisting", "type": "main", "index": 0}]]},
    "checkExisting": {"main": [[{"node": "updateCRM", "type": "main", "index": 0}, {"node": "updateERP", "type": "main", "index": 0}]]},
    "updateCRM": {"main": [[{"node": "log", "type": "main", "index": 0}]]},
    "updateERP": {"main": [[{"node": "log", "type": "main", "index": 0}]]}
  },
  "meta": {
    "company": "Universal",
    "useCase": "CRM-to-ERP Sync",
    "version": "2.0",
    "nodes": 8,
    "author": "Mission Control",
    "status": "production-ready"
  }
}
