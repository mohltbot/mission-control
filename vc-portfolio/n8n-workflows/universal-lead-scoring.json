{
  "name": "Universal - Lead Scoring",
  "description": "Auto-qualify prospects from multiple sources, score leads, route to sales",
  "version": "2.0",
  "nodes": [
    {
      "id": "multiTrigger",
      "type": "n8n-nodes-base.webhook",
      "name": "Lead Captured",
      "parameters": {
        "path": "lead-capture",
        "responseMode": "responseNode"
      }
    },
    {
      "id": "enrich",
      "type": "n8n-nodes-base.clearbit",
      "name": "Enrich Lead Data",
      "parameters": {
        "email": "={{ $json.email }}"
      }
    },
    {
      "id": "score",
      "type": "n8n-nodes-base.function",
      "name": "Score Lead",
      "parameters": {
        "functionCode": "const lead = $input.first().json;\nlet score = 0;\n// Company size\nif (lead.company?.employees > 100) score += 20;\nif (lead.company?.employees > 500) score += 30;\n// Title\nconst titles = ['ceo', 'cto', 'vp', 'director', 'head'];\nif (titles.some(t => lead.title?.toLowerCase().includes(t))) score += 25;\n// Source quality\nif (lead.source === 'demo-request') score += 30;\nif (lead.source === 'pricing-page') score += 20;\n// Engagement\nif (lead.websiteVisits > 3) score += 15;\nreturn { ...lead, score, qualified: score >= 60 };"
      }
    },
    {
      "id": "route",
      "type": "n8n-nodes-base.switch",
      "name": "Route by Score",
      "parameters": {
        "rules": [
          {"value": ">=80", "output": 0},
          {"value": ">=60", "output": 1},
          {"value": "<60", "output": 2}
        ]
      }
    },
    {
      "id": "hotLead",
      "type": "n8n-nodes-base.slack",
      "name": "Alert Sales - HOT",
      "parameters": {
        "channel": "#hot-leads",
        "text": "🔥 HOT LEAD (Score: {{ $json.score }})\n{{ $json.name }} - {{ $json.title }}\n{{ $json.company.name }} ({{ $json.company.employees }} employees)\nPhone: {{ $json.phone }}\nAction: Call within 15 minutes!"
      }
    },
    {
      "id": "warmLead",
      "type": "n8n-nodes-base.salesforce",
      "name": "Create Opportunity",
      "parameters": {
        "operation": "create",
        "resource": "lead",
        "firstname": "={{ $json.firstName }}",
        "lastname": "={{ $json.lastName }}",
        "email": "={{ $json.email }}",
        "company": "={{ $json.company.name }}",
        "leadSource": "={{ $json.source }}",
        "rating": "Warm"
      }
    },
    {
      "id": "nurture",
      "type": "n8n-nodes-base.activeCampaign",
      "name": "Add to Nurture",
      "parameters": {
        "operation": "create",
        "email": "={{ $json.email }}",
        "listId": "nurture-sequence"
      }
    },
    {
      "id": "crmLog",
      "type": "n8n-nodes-base.googleSheets",
      "name": "Log All Leads",
      "parameters": {
        "operation": "append",
        "sheetId": "leads-tracking",
        "range": "Leads!A:G",
        "values": [
          "={{ $now }}",
          "={{ $json.email }}",
          "={{ $json.name }}",
          "={{ $json.company.name }}",
          "={{ $json.score }}",
          "={{ $json.qualified }}"
        ]
      }
    }
  ],
  "connections": {
    "multiTrigger": {"main": [[{"node": "enrich", "type": "main", "index": 0}]]},
    "enrich": {"main": [[{"node": "score", "type": "main", "index": 0}]]},
    "score": {"main": [[{"node": "route", "type": "main", "index": 0}]]},
    "route": {
      "main": [
        [{"node": "hotLead", "type": "main", "index": 0}],
        [{"node": "warmLead", "type": "main", "index": 0}],
        [{"node": "nurture", "type": "main", "index": 0}]
      ]
    },
    "hotLead": {"main": [[{"node": "crmLog", "type": "main", "index": 0}]]},
    "warmLead": {"main": [[{"node": "crmLog", "type": "main", "index": 0}]]},
    "nurture": {"main": [[{"node": "crmLog", "type": "main", "index": 0}]]}
  },
  "meta": {
    "company": "Universal",
    "useCase": "Lead Scoring",
    "version": "2.0",
    "nodes": 8,
    "author": "Mission Control",
    "status": "production-ready"
  }
}
